<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>SIJA-JOBNET</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
        html, body { height: 100%; overflow-x: hidden; overscroll-behavior: none; }
        #profileMenu:not(.hidden) { animation: fadeInScale 0.2s ease-out forwards; }
        @keyframes fadeInScale {
            from { opacity: 0; transform: scale(0.95) translateY(-10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
    </style>
</head>
<body class="bg-slate-50">

    <% 
        // Inisialisasi Data
        safeUser = (typeof user !== 'undefined' && user) ? user : {};
        companyName = safeUser.name || 'Perusahaan';
        companyFirstName = companyName.split(' ')[0];
        logoDefault = "https://ui-avatars.com/api/?name=" + encodeURIComponent(companyName) + "&background=7f97d9&color=fff";
        companyLogo = safeUser.logo ? '/uploads/logos/' + safeUser.logo : logoDefault;

        // Cek halaman aktif (dikirim dari res.render)
        const active = (typeof currentPage !== 'undefined') ? currentPage : '';
    %>

    <nav class="bg-[#7f97d9] h-[70px] flex items-center justify-between px-8 sticky top-0 z-50 shadow-lg text-white">
        <div class="flex items-center gap-3 font-bold text-2xl tracking-tighter">
            <img src="/images/LOGO-STM.png" class="h-10 w-auto invert brightness-0" alt="Logo">
            <span>STM JOB</span>
        </div>
        
        <div class="flex items-center gap-8">
            <ul class="hidden md:flex gap-8 text-sm font-semibold uppercase tracking-wider">
                <li>
                    <a href="/dashboard/perusahaan" 
                       class="<%= active === 'dashboard' ? 'border-b-2 border-white pb-1' : 'hover:text-slate-200 transition-all' %>">
                       Dashboard
                    </a>
                </li>
                <li>
                    <a href="/career-perusahaan" 
                       class="<%= active === 'career' ? 'border-b-2 border-white pb-1' : 'hover:text-slate-200 transition-all' %>">
                       Create Job
                    </a>
                </li>
                <li>
                    <a href="/kelola-loker" 
                       class="<%= active === 'manage' ? 'border-b-2 border-white pb-1' : 'hover:text-slate-200 transition-all' %>">
                       Manage Job
                    </a>
                </li>
                <li>
                    <a href="/help-perusahaan" 
                       class="<%= active === 'help' ? 'border-b-2 border-white pb-1' : 'hover:text-slate-200 transition-all' %>">
                       Help
                    </a>
                </li>
            </ul>

            <div class="relative inline-block text-left" id="profileDropdownContainer">
                <button id="profileDropdownBtn" class="flex items-center gap-3 bg-white/10 pl-4 pr-1 py-1 rounded-full border border-white/20 hover:bg-white/20 transition-all cursor-pointer">
                    <span class="text-xs font-bold hidden sm:block"><%= companyFirstName %></span>
                    <div class="h-9 w-9 rounded-full bg-white flex items-center justify-center overflow-hidden border border-slate-100">
                        <img src="<%= companyLogo %>" onerror="this.src='<%= logoDefault %>'" class="w-full h-full object-cover">
                    </div>
                </button>

                <div id="profileMenu" class="hidden absolute right-0 mt-3 w-56 bg-white rounded-[1.5rem] shadow-2xl border border-slate-100 z-[100] overflow-hidden transform">
                    <div class="py-2">
                        <div class="px-4 py-3 border-b border-slate-50 mb-1 bg-slate-50/50">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1.5">Industrial Partner</p>
                            <p class="text-xs font-bold text-slate-700 truncate"><%= companyName %></p>
                        </div>
                        <a href="/perusahaan/profil" class="flex items-center px-4 py-3 text-[11px] font-bold text-slate-600 hover:bg-slate-50 transition-all">PROFIL SAYA</a>
                        <a href="/logout" class="flex items-center px-4 py-3 text-[11px] font-bold text-red-500 hover:bg-red-50 transition-all">KELUAR APLIKASI</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <script>
        // Script Dropdown
        const profileBtn = document.getElementById('profileDropdownBtn');
        const profileMenu = document.getElementById('profileMenu');
        if(profileBtn) {
            profileBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                profileMenu.classList.toggle('hidden');
            });
            document.addEventListener('click', (e) => {
                if (!profileDropdownContainer.contains(e.target)) profileMenu.classList.add('hidden');
            });
        }
    </script>