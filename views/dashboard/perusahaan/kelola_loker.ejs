<%- include('partials/header', { currentPage: 'manage', title: 'Kelola Loker - STM JOB' }) %>

<main class="max-w-7xl mx-auto px-4 md:px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-12 gap-6">
        <div>
            <h2 class="text-xs font-black text-slate-400 uppercase tracking-[0.4em] flex items-center gap-3 mb-2">
                <span class="w-12 h-[3px] bg-[#7f97d9] rounded-full"></span> Job Management
            </h2>
            <h1 class="text-3xl font-black text-slate-800">Daftar Lowongan Anda</h1>
        </div>
        <a href="/career-perusahaan" class="w-full md:w-auto text-center px-8 py-4 bg-slate-900 text-white text-xs font-black uppercase tracking-widest rounded-2xl shadow-xl hover:bg-[#7f97d9] transition-all active:scale-95">
            + Tambah Loker Baru
        </a>
    </div>

    <div class="bg-white rounded-[2rem] md:rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[600px]">
                <thead class="bg-slate-50/50 text-slate-500 uppercase text-[10px] font-black tracking-widest">
                    <tr>
                        <th class="p-6 md:p-8">Posisi & Detail</th>
                        <th class="p-6 md:p-8 text-center">Status</th>
                        <th class="p-6 md:p-8 text-center">Total Pelamar</th>
                        <th class="p-6 md:p-8 text-right">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% if (typeof listLoker !== 'undefined' && listLoker.length > 0) { %>
                        <% listLoker.forEach(loker => { %>
                        <tr class="hover:bg-slate-50/30 transition-all group">
                            <td class="p-6 md:p-8">
                                <div class="flex flex-col">
                                    <p class="font-extrabold text-slate-800 text-lg leading-tight mb-1"><%= loker.judul %></p>
                                    <div class="flex items-center gap-4">
                                        <span class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider">
                                            📅 <%= new Date(loker.createdAt || Date.now()).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                        </span>
                                        <a href="/api/lowongan/<%= loker._id %>/pelamar" class="text-[10px] font-black text-[#7f97d9] uppercase tracking-widest hover:underline">
                                            Lihat List Pelamar →
                                        </a>
                                    </div>
                                </div>
                            </td>

                            <td class="p-6 md:p-8 text-center">
                                <% if(loker.status === 'Aktif') { %>
                                    <span class="inline-flex items-center px-4 py-1.5 bg-emerald-50 text-emerald-600 rounded-full text-[10px] font-black uppercase tracking-tighter border border-emerald-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-2 animate-pulse"></span> Aktif
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-4 py-1.5 bg-slate-100 text-slate-500 rounded-full text-[10px] font-black uppercase tracking-tighter border border-slate-200">
                                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400 mr-2"></span> Tutup
                                    </span>
                                <% } %>
                            </td>

                            <td class="p-6 md:p-8 text-center">
                                <a href="/api/lowongan/<%= loker._id %>/pelamar" class="inline-flex flex-col items-center group/btn">
                                    <span class="text-2xl font-black text-slate-800 group-hover/btn:text-[#7f97d9] transition-colors leading-none">
                                        <%= (loker.jumlahPelamar) ? loker.jumlahPelamar : 0 %>
                                    </span>
                                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider mt-1 underline decoration-transparent group-hover/btn:decoration-[#7f97d9]">Lihat Pelamar</span>
                                </a>
                            </td>

                            <td class="p-6 md:p-8 text-right">
                                <div class="flex justify-end items-center gap-2 md:gap-3">
                                    <form action="/api/lowongan/toggle-status/<%= loker._id %>" method="POST" class="inline">
                                        <button type="submit" class="px-4 md:px-5 py-2.5 <%= (loker.status === 'Aktif') ? 'bg-amber-50 text-amber-600 hover:bg-amber-500 hover:text-white' : 'bg-blue-50 text-blue-600 hover:bg-blue-500 hover:text-white' %> rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-sm active:scale-95">
                                            <%= (loker.status === 'Aktif') ? 'Nonaktifkan' : 'Aktifkan' %>
                                        </button>
                                    </form>
                                    
                                    <form id="delete-form-<%= loker._id %>" action="/api/lowongan/delete/<%= loker._id %>" method="POST" class="inline">
                                        <button type="button" onclick="confirmDelete('<%= loker._id %>')" class="p-2.5 bg-slate-50 text-slate-400 rounded-xl hover:bg-red-500 hover:text-white transition-all shadow-sm active:scale-95">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="p-20 text-center">
                                <div class="flex flex-col items-center opacity-30">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    <p class="text-sm font-bold uppercase tracking-widest">Belum ada lowongan yang dibuat</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(id) {
        Swal.fire({
            title: 'Hapus Lowongan?',
            text: "Data pendaftaran pelamar juga akan terhapus permanen!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Ya, Hapus!',
            cancelButtonText: 'Batal',
            borderRadius: '2rem'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('delete-form-' + id).submit();
            }
        })
    }
</script>

<%- include('partials/footer') %>