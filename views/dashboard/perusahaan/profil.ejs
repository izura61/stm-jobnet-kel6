<%- include('partials/header', { title: 'Profil Perusahaan - STM JOB', currentPage: 'profile' }) %>

<style>
    :root {
        --primary-blue: #7f97d9;
        --deep-indigo: #4f46e5;
        --slate-bg: #f8fafc;
    }
    .profile-main { background-color: #fdfeff; min-height: 100vh; }
    .banner-mesh {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--deep-indigo) 100%);
        height: 200px;
        border-radius: 3rem;
        position: relative;
        overflow: hidden;
    }
    .logo-container {
        height: 8rem; 
        width: 8rem; 
        flex-shrink: 0;
        border-radius: 2.5rem;
        background: white;
        padding: 0.5rem;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        border: 4px solid white;
        overflow: hidden;
    }
    .logo-container img { width: 100%; height: 100%; object-fit: contain; border-radius: 2rem; }
    .premium-card {
        background: rgba(255, 255, 255, 1);
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04);
        border-radius: 3rem;
    }
    .input-box {
        width: 100%;
        padding: 1.1rem;
        background-color: #f8fafc;
        border: 2px solid #f1f5f9;
        border-radius: 1.5rem;
        font-size: 13px;
        font-weight: 700;
        color: #334155;
        outline: none;
        transition: all 0.3s ease;
    }
    .input-box:focus {
        border-color: var(--primary-blue);
        background-color: #fff;
        box-shadow: 0 8px 20px -5px rgba(127, 151, 217, 0.15);
    }
    .label-caps {
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #94a3b8;
        margin-bottom: 0.5rem;
        display: block;
    }
    .btn-update {
        background: var(--primary-blue);
        color: white;
        width: 100%;
        padding: 1.25rem;
        border-radius: 1.5rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 11px;
        transition: all 0.3s ease;
    }
    .btn-update:hover {
        background: var(--deep-indigo);
        transform: translateY(-2px);
        box-shadow: 0 12px 20px -5px rgba(79, 70, 229, 0.3);
    }
    .justify-text { text-align: justify; text-justify: inter-word; }
</style>

<main class="profile-main max-w-7xl mx-auto px-6 py-10">
    
    <% 
        const pName = (user && user.name) ? user.name : 'Company Name';
        const defaultLogo = "https://ui-avatars.com/api/?name=" + encodeURIComponent(pName) + "&background=7f97d9&color=fff&size=256";
        const logoPath = (user && user.logo && user.logo !== 'default-logo.png') ? '/uploads/logos/' + user.logo : defaultLogo;
    %>

    <div class="relative mb-24">
        <div class="banner-mesh shadow-lg"></div>
        <div class="absolute -bottom-12 left-10 flex flex-row items-end gap-6 w-[calc(100%-80px)]">
            <div class="logo-container">
                <img src="<%= logoPath %>" onerror="this.src='<%= defaultLogo %>'" alt="Logo">
            </div>
            <div class="mb-4 flex-1">
                <h1 class="text-2xl md:text-4xl font-black text-slate-800 tracking-tight leading-tight uppercase truncate">
                    <%= pName %>
                </h1>
                <p class="text-[#7f97d9] font-bold uppercase text-[10px] md:text-xs tracking-[0.2em] mt-1">
                    ID MITRA: <%= user._id.toString().substring(0,8).toUpperCase() %>
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10"> 
        <div class="lg:col-span-4 space-y-6">
            <div class="premium-card p-8">
                <h3 class="label-caps mb-6 text-indigo-600">Info Kontak</h3>
                <div class="space-y-4">
                    <div>
                        <p class="label-caps opacity-60">Email</p>
                        <p class="text-xs font-black text-slate-700 break-all"><%= user.email %></p>
                    </div>
                    <div>
                        <p class="label-caps opacity-60">Telepon</p>
                        <p class="text-xs font-black text-slate-700"><%= user.telepon || '-' %></p>
                    </div>
                    <div>
                        <p class="label-caps opacity-60">Website Resmi</p>
                        <% if (user.website) { %>
                            <a href="<%= user.website %>" target="_blank" rel="noopener noreferrer" class="text-xs font-black text-indigo-600 hover:underline break-all">
                                <%= user.website %>
                            </a>
                        <% } else { %>
                            <p class="text-xs font-black text-slate-400">Belum ditambahkan</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900 p-8 rounded-[2.5rem] text-white">
                <h3 class="label-caps opacity-40 text-white mb-4">Bio Singkat</h3>
                <p class="text-xs leading-relaxed font-medium text-slate-400 justify-text">
                    <%= user.deskripsi || 'Belum ada deskripsi profil.' %>
                </p>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="premium-card p-8 md:p-12">
                <div class="flex items-center gap-4 mb-10">
                    <div class="h-12 w-12 bg-indigo-50 rounded-xl flex items-center justify-center text-xl">⚙️</div>
                    <div>
                        <h3 class="text-xl font-black text-slate-800 leading-none">Edit Profile</h3>
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Perbarui identitas industri Anda</p>
                    </div>
                </div>

                <form id="formUpdatePerusahaan" action="/api/perusahaan/update-profil" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="group">
                            <label class="label-caps">Identity Logo (PNG/JPG)</label>
                            <input type="file" name="logo" id="inputLogo" accept="image/png, image/jpeg, image/jpg" 
                                class="w-full mt-1 p-3 bg-slate-50 border-2 border-slate-100 rounded-2xl text-[10px] font-bold file:bg-slate-800 file:text-white file:border-0 file:rounded-full file:px-4 file:py-1 file:mr-4 file:uppercase file:text-[9px]">
                        </div>
                        <div class="group">
                            <label class="label-caps">Company Name</label>
                            <input type="text" name="name" value="<%= pName %>" required class="input-box">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="label-caps">Public Email</label>
                            <input type="email" name="email" value="<%= user.email %>" required class="input-box">
                        </div>
                        <div>
                            <label class="label-caps">Corporate Phone</label>
                            <input type="text" name="telepon" value="<%= user.telepon || '' %>" required class="input-box">
                        </div>
                    </div>

                    <div>
                        <label class="label-caps">Website Resmi Perusahaan</label>
                        <input type="url" name="website" value="<%= user.website || '' %>" class="input-box" placeholder="https://www.perusahaananda.co.id">
                    </div>

                    <div>
                        <label class="label-caps">Headquarters Address</label>
                        <textarea name="alamat" rows="2" required class="input-box resize-none"><%= user.alamat || '' %></textarea>
                    </div>

                    <div>
                        <label class="label-caps">Industry Focus (Gunakan Koma)</label>
                        <input type="text" name="bidangIndustri" value="<%= (user.bidangIndustri && Array.isArray(user.bidangIndustri)) ? user.bidangIndustri.join(', ') : (user.bidangIndustri || '') %>" class="input-box" placeholder="IT, Manufaktur, Desain">
                    </div>

                    <div>
                        <label class="label-caps">Corporate Bio</label>
                        <textarea name="deskripsi" rows="5" required class="input-box resize-none leading-relaxed"><%= user.deskripsi || '' %></textarea>
                    </div>

                    <button type="submit" class="btn-update">
                        Simpan Perubahan Profil
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const form = document.getElementById('formUpdatePerusahaan');
    const inputLogo = document.getElementById('inputLogo');
    const params = new URLSearchParams(window.location.search);
    const errorMsg = params.get('error');
    const statusMsg = params.get('status');

    if (errorMsg) {
        Swal.fire({ icon: 'error', title: 'Gagal Update', text: errorMsg, confirmButtonColor: '#7f97d9', borderRadius: '1.5rem' });
        window.history.replaceState({}, document.title, window.location.pathname);
    }

    if (statusMsg === 'success') {
        Swal.fire({ icon: 'success', title: 'Berhasil!', text: 'Profil perusahaan telah diperbarui.', timer: 2500, showConfirmButton: false, borderRadius: '2rem' });
        window.history.replaceState({}, document.title, window.location.pathname);
    }

    const initialData = new FormData(form);
    const initialEntries = {};
    for (let [key, value] of initialData.entries()) {
        if (key !== 'logo') initialEntries[key] = value;
    }

    inputLogo.addEventListener('change', function() {
        const file = this.files[0];
        if (file) {
            const fileType = file.type;
            const validTypes = ['image/png', 'image/jpeg', 'image/jpg'];
            if (!validTypes.includes(fileType)) {
                Swal.fire({ icon: 'error', title: 'Format Salah', text: 'Hanya diperbolehkan file gambar PNG, JPG, atau JPEG!', borderRadius: '1.5rem', confirmButtonColor: '#7f97d9' });
                this.value = '';
            }
        }
    });

    form.onsubmit = function(e) {
        e.preventDefault();
        const currentData = new FormData(form);
        let isChanged = inputLogo.files.length > 0;
        if (!isChanged) {
            for (let [key, value] of currentData.entries()) {
                if (key !== 'logo' && value !== initialEntries[key]) { isChanged = true; break; }
            }
        }
        if (!isChanged) {
            Swal.fire({ icon: 'info', title: 'Tidak Ada Perubahan', text: 'Anda belum mengubah data apa pun.', borderRadius: '1.5rem', confirmButtonColor: '#7f97d9' });
            return false;
        }
        Swal.fire({ title: 'Sedang Menyimpan...', text: 'Mohon tunggu sebentar', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
        form.submit();
    };
</script>

<%- include('partials/footer') %>