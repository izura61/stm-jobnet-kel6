<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup Profil | <%= user.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { --primary: #2563eb; --bg: #f3f4f6; }
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background: var(--bg); 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            margin: 0; 
            padding: 20px;
        }
        .container-custom { 
            background: white; 
            padding: 2rem; 
            border-radius: 24px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
            width: 100%; 
            max-width: 900px; 
            height: fit-content;
        }
        .header { text-align: center; margin-bottom: 2rem; }
        .header h1 { font-size: 1.8rem; color: #1f2937; word-wrap: break-word; font-weight: 800; }
        .header p { color: #6b7280; font-size: 0.95rem; }

        .setup-wrapper { 
            display: grid; 
            grid-template-columns: 1fr 2fr; 
            gap: 2.5rem; 
            align-items: start; 
        }
        
        .photo-section { 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            position: sticky; 
            top: 20px;
        }
        .photo-box { 
            width: 180px; 
            height: 180px; 
            border: 2px dashed #d1d5db; 
            border-radius: 20px; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            overflow: hidden; 
            background: #fafafa; 
            cursor: pointer; 
            transition: 0.3s; 
        }
        .photo-box img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
        .photo-box:hover { border-color: var(--primary); background: #f0f7ff; }

        .form-content { display: flex; flex-direction: column; gap: 1.2rem; }
        
        label { display: block; font-weight: 600; margin-bottom: 8px; color: #374151; font-size: 14px; }
        
        input[type="text"], input[type="url"], textarea { 
            width: 100%; 
            padding: 14px; 
            border: 2px solid #e5e7eb; 
            border-radius: 12px; 
            box-sizing: border-box; 
            font-size: 15px; 
            transition: 0.3s; 
            background: #f9fafb;
        }
        
        textarea { min-height: 80px; resize: vertical; line-height: 1.6; }
        
        input:focus, textarea:focus { 
            outline: none; 
            border-color: var(--primary); 
            background: white;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1); 
        }

        .btn-submit { 
            width: 100%; 
            background: var(--primary); 
            color: white; 
            padding: 16px; 
            border: none; 
            border-radius: 12px; 
            font-size: 16px; 
            font-weight: 800; 
            cursor: pointer; 
            transition: 0.3s; 
            margin-top: 10px;
            letter-spacing: 0.5px;
        }
        .btn-submit:hover { background: #1d4ed8; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(37, 99, 235, 0.3); }

        .custom-file-upload { 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            border: 2px dashed #e5e7eb;
        }
        .custom-file-upload:hover { border-color: #7f97d9; background-color: rgba(127, 151, 217, 0.05); }

        @media (max-width: 768px) { 
            .setup-wrapper { grid-template-columns: 1fr; gap: 1.5rem; } 
            .photo-section { position: relative; top: 0; }
            .container-custom { padding: 1.5rem; border-radius: 16px; }
        }
    </style>
</head>
<body>

<div class="container-custom">
    <div class="header">
        <h1>Lengkapi Profil Perusahaan</h1>
        <p>Halo <strong><%= user.name %></strong>, mohon lengkapi data agar bisa mulai pasang lowongan.</p>
    </div>

    <form action="/api/perusahaan/update-profil" method="POST" enctype="multipart/form-data" class="setup-wrapper">
        
        <div class="photo-section">
            <label>Logo Perusahaan</label>
            <div class="photo-box" onclick="document.getElementById('logoInput').click()">
                <% 
                    const currentLogo = (user.logo && user.logo !== 'default-logo.png') ? '/uploads/logos/' + user.logo : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=2563eb&color=fff';
                %>
                <img id="preview" src="<%= currentLogo %>" alt="Preview Logo">
            </div>
            <p style="font-size: 12px; color: #9ca3af; margin-top: 12px;">Format JPG/PNG, Maks 2MB</p>
            <input type="file" name="logo" id="logoInput" accept="image/*" style="display:none" onchange="previewImage(this)">
        </div>

        <div class="form-content">
            <div class="form-group">
                <label>Nama Perusahaan</label>
                <input type="text" name="name" value="<%= user.name %>" placeholder="Masukkan nama resmi perusahaan" required>
            </div>

            <div class="form-group">
                <label>Bidang Industri</label>
                <input type="text" name="bidangIndustri" placeholder="Contoh: Teknologi, Manufaktur, Logistik" required>
            </div>

            <div class="form-group">
                <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">
                    Company Profile / Dokumen (PDF) <span class="text-[8px] text-slate-300">- Opsional</span>
                </label>
                <label for="cv" class="custom-file-upload flex items-center justify-between w-full px-5 py-3 bg-slate-50 rounded-2xl cursor-pointer">
                    <div class="flex items-center gap-3 min-w-0 flex-1"> 
                        <div class="p-2 bg-white rounded-xl shadow-sm flex-shrink-0">
                            <svg class="w-5 h-5 text-[#7f97d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                        </div>
                        <span id="cv-filename" class="text-xs font-bold text-slate-400 tracking-tight truncate">Pilih PDF jika ada (Maks 20MB)</span>
                    </div>
                    <span class="text-[9px] flex-shrink-0 font-black text-white bg-[#7f97d9] px-3 py-1.5 rounded-lg uppercase tracking-widest ml-2">Upload</span>
                </label>
                <input type="file" name="cv" id="cv" accept=".pdf" class="hidden" onchange="updateFileName(this)">
            </div>
            <div class="form-group">
                <label>Alamat Lengkap Kantor</label>
                <textarea name="alamat" placeholder="Tuliskan alamat lengkap kantor pusat..." required></textarea>
            </div>

            <div class="form-group">
                <label>Nomor Telepon / WhatsApp</label>
                <input type="text" name="telepon" placeholder="Contoh: 0812xxxx" required>
            </div>

            <div class="form-group">
                <label>Website Resmi (Opsional)</label>
                <input type="url" name="website" placeholder="https://www.perusahaananda.com">
            </div>

            <div class="form-group">
                <label>Tentang Perusahaan</label>
                <textarea name="deskripsi" style="height: 120px;" placeholder="Jelaskan visi, misi, atau budaya kerja perusahaan..." required></textarea>
            </div>

            <button type="submit" class="btn-submit">Selesaikan Pendaftaran Profil</button>
        </div>
    </form>
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) { 
                document.getElementById('preview').src = e.target.result; 
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Fungsi untuk mengubah teks nama file CV saat dipilih
    function updateFileName(input) {
        const display = document.getElementById('cv-filename');
        if (input.files && input.files[0]) {
            display.innerText = input.files[0].name;
            display.classList.replace('text-slate-400', 'text-slate-700');
        } else {
            display.innerText = "Pilih PDF jika ada (Maks 20MB)";
            display.classList.replace('text-slate-700', 'text-slate-400');
        }
    }
</script>

</body>
</html>