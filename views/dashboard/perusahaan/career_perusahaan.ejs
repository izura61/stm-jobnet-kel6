<%- include('partials/header', { currentPage: 'career', title: 'Post Job - STM JOB' }) %>

<main class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-10 text-center">
        <span class="inline-block px-4 py-1.5 bg-[#7f97d9]/10 text-[#7f97d9] text-[10px] font-black uppercase tracking-[0.3em] rounded-full mb-4">
            Recruitment Tools
        </span>
        <h1 class="text-4xl font-black text-slate-800 tracking-tight">Posting Lowongan Baru</h1>
        <p class="text-slate-500 mt-3 text-lg">Halo <%= user.name.split(' ')[0] %>, lengkapi detail pekerjaan untuk mendapatkan kandidat terbaik.</p>
    </div>

    <form action="/api/lowongan/create" method="POST" class="bg-white p-8 md:p-16 rounded-[3.5rem] border border-slate-100 shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="md:col-span-2">
                <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 ml-2">Judul Posisi Pekerjaan</label>
                <input type="text" name="judul" placeholder="Contoh: Junior Web Developer" required
                    class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none transition-all font-bold text-slate-700 placeholder:text-slate-300">
            </div>

            <div>
                <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 ml-2">Tipe Program</label>
                <div class="relative">
                    <select name="tipe" required class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none font-bold text-slate-700 appearance-none cursor-pointer">
                        <option value="" disabled selected>Pilih Tipe</option>
                        <option value="PKL">Praktik Kerja Lapangan (PKL)</option>
                        <option value="Magang">Magang Industri</option>
                        <option value="Kerja">Lulusan Baru (Full-time)</option>
                    </select>
                    <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 ml-2">Lokasi Penempatan</label>
                <input type="text" name="lokasi" placeholder="Contoh: Cimahi, Jawa Barat" required
                    class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none font-bold text-slate-700">
            </div>

            <div class="md:col-span-2">
                <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 ml-2">Estimasi Gaji (Opsional)</label>
                <input type="text" name="gaji" placeholder="Contoh: Rp 2.000.000 - Rp 4.000.000"
                    class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none font-bold text-slate-700">
            </div>

            <div class="md:col-span-2">
                <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 ml-2">Deskripsi Pekerjaan</label>
                <textarea name="deskripsi" rows="5" placeholder="Tuliskan poin-poin tanggung jawab..." required
                    class="w-full px-8 py-6 bg-slate-50 border border-slate-100 rounded-[2.5rem] focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none transition-all font-medium text-slate-600"></textarea>
            </div>

            <div class="md:col-span-2">
                <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 ml-2">Kualifikasi Khusus</label>
                <textarea name="kualifikasi" rows="5" placeholder="Contoh: Menguasai Javascript..." required
                    class="w-full px-8 py-6 bg-slate-50 border border-slate-100 rounded-[2.5rem] focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none transition-all font-medium text-slate-600"></textarea>
            </div>
        </div>

        <div class="mt-16 flex flex-col md:flex-row gap-5">
            <button type="submit" class="flex-[2] px-10 py-6 bg-slate-900 text-white rounded-[2rem] text-xs font-black uppercase tracking-[0.2em] shadow-2xl hover:bg-[#7f97d9] transition-all active:scale-95">
                Tayangkan Lowongan Sekarang
            </button>
            <a href="/dashboard/perusahaan" class="flex-1 px-10 py-6 bg-slate-100 text-slate-400 rounded-[2rem] text-xs font-black uppercase tracking-[0.2em] hover:bg-slate-200 transition-all flex items-center justify-center">
                Batalkan
            </a>
        </div>
    </form>
</main>

<%- include('partials/footer') %>