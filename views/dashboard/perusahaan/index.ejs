<%- include('partials/header', { currentPage: 'dashboard', title: 'Dashboard Perusahaan' }) %>

<main class="max-w-7xl mx-auto px-6 py-12">
    
    <div class="bg-white p-10 md:p-16 rounded-[3rem] border border-slate-100 shadow-sm mb-12 relative overflow-hidden">
        <div class="relative z-10 max-w-2xl">
            <span class="inline-block px-4 py-1.5 bg-[#7f97d9]/10 text-[#7f97d9] text-[10px] font-black uppercase tracking-[0.3em] rounded-full mb-4">
                Partner Dashboard
            </span>
            <h1 class="text-4xl md:text-5xl font-black text-slate-800 leading-tight">
                Halo, <span class="text-[#7f97d9]"><%= user.name.split(' ')[0] %></span>!
            </h1>
            <p class="text-slate-500 mt-4 text-xl leading-relaxed">
                Kelola lowongan pekerjaan dan temukan calon tenaga kerja terbaik dari SMK Negeri 1 Cimahi secara efisien.
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
                <a href="/career-perusahaan" class="px-8 py-4 bg-slate-900 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl hover:bg-[#7f97d9] transition-all active:scale-95 inline-block">
                    Posting Lowongan Baru
                </a>
                <a href="/kelola-loker" class="px-8 py-4 bg-white border border-slate-200 text-slate-600 rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-slate-50 transition-all inline-block">
                    Manajemen Pelamar
                </a>
            </div>
        </div>
        <div class="absolute right-[-5%] bottom-[-10%] w-80 h-80 bg-[#7f97d9]/5 rounded-full blur-3xl"></div>
    </div>

    <h2 class="text-xs font-black text-slate-400 uppercase tracking-[0.4em] mb-8 flex items-center gap-3">
        <span class="w-12 h-[3px] bg-[#7f97d9] rounded-full"></span> Performance Overview
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="bg-white border border-slate-100 p-8 rounded-[3rem] shadow-sm relative overflow-hidden group hover:border-[#7f97d9] transition-all">
            <div class="absolute top-0 right-0 w-24 h-24 bg-[#7f97d9]/5 rounded-bl-[3rem] -mr-4 -mt-4 transition-all group-hover:scale-110"></div>
            <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest mb-2">Total Postingan</p>
            <h3 class="text-5xl font-black text-slate-800 tracking-tighter">
                <%= stats.totalLoker %>
            </h3>
        </div>

        <div class="bg-white border border-slate-100 p-8 rounded-[3rem] shadow-sm relative overflow-hidden group hover:border-emerald-200 transition-all">
            <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-50 rounded-bl-[3rem] -mr-4 -mt-4 transition-all group-hover:scale-110"></div>
            <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest mb-2">Pelamar Masuk</p>
            <h3 class="text-5xl font-black text-slate-800 tracking-tighter">
                <%= stats.totalPelamar %>
            </h3>
        </div>

        <div class="bg-white border border-slate-100 p-8 rounded-[3rem] shadow-sm relative overflow-hidden group hover:border-amber-200 transition-all">
            <div class="absolute top-0 right-0 w-24 h-24 bg-amber-50 rounded-bl-[3rem] -mr-4 -mt-4 transition-all group-hover:scale-110"></div>
            <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest mb-2">Lowongan Aktif</p>
            <h3 class="text-5xl font-black text-slate-800 tracking-tighter">
                <%= stats.lokerAktif %>
            </h3>
        </div>
    </div>

    <div class="bg-slate-900 rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden shadow-2xl shadow-slate-200 mb-16">
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div class="max-w-xl">
                <h4 class="text-2xl font-bold mb-3">Butuh Bantuan Navigasi?</h4>
                <p class="text-slate-400 text-base leading-relaxed">
                    Kami menyediakan panduan lengkap untuk memudahkan Anda mengelola akun industri, mulai dari pembuatan lowongan hingga proses seleksi pelamar.
                </p>
            </div>
            <a href="/dashboard/perusahaan/guide_book" class="inline-flex items-center justify-center px-8 py-4 bg-[#7f97d9] text-white rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-white hover:text-[#7f97d9] transition-all group">
                Buka Panduan Utama <span class="ml-2 transition-transform group-hover:translate-x-2">→</span>
            </a>
        </div>
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white/5 to-transparent"></div>
    </div>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white border border-slate-100 p-10 rounded-[3rem] shadow-sm flex items-center gap-6">
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center text-3xl">🛡️</div>
            <div>
                <h5 class="font-bold text-slate-800 text-lg">Keamanan Akun</h5>
                <p class="text-slate-400 text-sm">Pastikan data perusahaan Anda valid untuk menjaga kredibilitas di mata pelamar.</p>
                <a href="/perusahaan/profil" class="text-[#7f97d9] text-xs font-bold mt-2 inline-block uppercase">Update Profil →</a>
            </div>
        </div>
        <div class="bg-white border border-slate-100 p-10 rounded-[3rem] shadow-sm flex items-center gap-6">
            <div class="w-16 h-16 bg-purple-50 text-purple-500 rounded-2xl flex items-center justify-center text-3xl">⚙️</div>
            <div>
                <h5 class="font-bold text-slate-800 text-lg">Pusat Bantuan</h5>
                <p class="text-slate-400 text-sm">Punya kendala teknis? Tim support kami siap membantu operasional dashboard Anda.</p>
                <a href="/help-perusahaan" class="text-[#7f97d9] text-xs font-bold mt-2 inline-block uppercase">Hubungi Support →</a>
            </div>
        </div>
    </section>

</main>

<%- include('partials/footer') %>