<% if (listPendaftar && listPendaftar.length > 0) { %>
    <div class="divide-y divide-slate-100">
        <% listPendaftar.forEach(p => { %> 
            <div class="p-8 md:p-10 hover:bg-slate-50 transition-all">
                <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
                    
                    <div class="flex items-center gap-6">
                        <% if (p.pendaftar) { %>
                            <div class="h-24 w-24 md:h-28 md:w-28 rounded-[2rem] overflow-hidden shadow-md border-4 border-white flex-shrink-0">
                                <img src="/uploads/profile/<%= p.pendaftar.foto || 'default.jpg' %>" class="w-full h-full object-cover">
                            </div>
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="text-xl font-black text-slate-800"><%= p.pendaftar.name %></h3>
                                    <span class="px-3 py-1 bg-blue-100 text-blue-600 text-[9px] font-black uppercase tracking-widest rounded-full">Siswa</span>
                                </div>
                                <p class="text-sm font-bold text-slate-500 uppercase tracking-tighter">NIS: <%= p.pendaftar.nis %></p>
                            </div>

                        <% } else if (p.tamu && p.tamu.isGuest) { %>
                            <div class="h-24 w-24 md:h-28 md:w-28 rounded-[2rem] bg-gradient-to-br from-[#7f97d9] to-indigo-600 flex items-center justify-center text-white text-3xl font-black shadow-lg flex-shrink-0 border-4 border-white">
                                <%= p.tamu.nama.charAt(0).toUpperCase() %>
                            </div>
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="text-xl font-black text-slate-800"><%= p.tamu.nama %></h3>
                                    <span class="px-3 py-1 bg-amber-100 text-amber-600 text-[9px] font-black uppercase tracking-widest rounded-full">Tamu / Umum</span>
                                </div>
                                <p class="text-sm font-bold text-slate-500 uppercase tracking-tighter">Pendaftar Luar</p>
                            </div>
                        <% } %>
                    </div>

                    <div class="flex flex-wrap md:flex-nowrap items-center gap-4 w-full md:w-auto">
                        <div class="grid grid-cols-1 gap-2 mr-4">
                            <div class="flex items-center gap-2 text-slate-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                <span class="text-xs font-bold"><%= p.pendaftar ? p.pendaftar.email : p.tamu.email %></span>
                            </div>
                            <div class="flex items-center gap-2 text-slate-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                                </svg>
                                <span class="text-xs font-bold text-slate-700"><%= p.pendaftar ? p.pendaftar.whatsapp : (p.tamu.whatsapp || '-') %></span>
                            </div>
                        </div>

                        <% 
                            let cvLink = "#";
                            if (p.pendaftar && p.pendaftar.cv) {
                                cvLink = "/uploads/cv/" + p.pendaftar.cv;
                            } else if (p.cv_tamu) {
                                cvLink = "/uploads/cv/" + p.cv_tamu;
                            }
                        %>
                        <% if (cvLink !== "#") { %>
                            <a href="<%= cvLink %>" target="_blank" class="flex items-center gap-3 px-6 py-3 bg-white border-2 border-slate-100 rounded-2xl hover:border-[#7f97d9] hover:text-[#7f97d9] transition-all group">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 group-hover:text-[#7f97d9]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                <div class="text-left">
                                    <p class="text-[9px] font-black uppercase tracking-widest leading-none mb-1">Unduh Dokumen</p>
                                    <p class="text-[11px] font-black uppercase">Kurikulum Vitae (CV)</p>
                                </div>
                            </a>
                        <% } else { %>
                            <div class="px-6 py-3 bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl text-slate-400">
                                <p class="text-[10px] font-bold uppercase tracking-widest italic text-center">CV Belum Diunggah</p>
                            </div>
                        <% } %>
                    </div>

                </div>
            </div>
        <% }) %>
    </div>
<% } else { %>
    <div class="p-20 text-center bg-slate-50/50 rounded-[3rem] border-4 border-dashed border-slate-100 m-8">
        <div class="flex flex-col items-center opacity-20 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
        </div>
        <p class="text-sm font-black text-slate-400 uppercase tracking-[0.2em]">Belum ada pelamar yang mendaftar</p>
    </div>
<% } %>