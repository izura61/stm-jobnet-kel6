<%- include('partials/header', { title: 'Mitra Perusahaan - STM JOB', currentPage: 'company' }) %>

<main class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div>
            <h2 class="text-xs font-black text-slate-400 uppercase tracking-[0.4em] flex items-center gap-3 mb-4">
                <span class="w-12 h-[3px] bg-[#7f97d9] rounded-full"></span> Industry Partners
            </h2>
            <h1 class="text-4xl font-black text-slate-800 tracking-tight">Featured Companies</h1>
            <p class="text-slate-500 mt-2 font-medium">Bekerja sama dengan perusahaan teknologi terkemuka untuk karirmu.</p>
        </div>

        <div class="relative group w-full md:w-96">
            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#7f97d9] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <input type="text" id="companySearch" onkeyup="filterCompanies()"
                class="w-full pl-12 pr-6 py-4 bg-white border-2 border-slate-100 rounded-2xl shadow-sm focus:ring-4 focus:ring-[#7f97d9]/10 focus:border-[#7f97d9] outline-none transition-all text-sm font-semibold"
                placeholder="Cari mitra perusahaan...">
        </div>
    </div>

    <div id="companyGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% if (listPerusahaan && listPerusahaan.length > 0) { %>
            <% listPerusahaan.forEach(perusahaan => { %>
                <div class="company-card group bg-gradient-to-b from-white to-slate-50 border border-slate-100 p-8 rounded-[3rem] text-center shadow-sm hover:shadow-xl hover:-translate-y-3 transition-all duration-500 relative overflow-hidden">
                    
                    <div class="absolute -right-6 -top-6 w-24 h-24 bg-[#7f97d9]/5 rounded-full group-hover:scale-150 transition-transform duration-700"></div>

                    <div class="w-24 h-24 bg-white rounded-[2rem] p-4 mx-auto mb-6 shadow-sm border border-slate-50 relative z-10 flex items-center justify-center">
                        <img src="/uploads/logos/<%= perusahaan.logo %>" 
                             alt="<%= perusahaan.name %>"
                             class="max-w-full max-h-full object-contain group-hover:scale-110 transition-transform duration-500"
                             onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(perusahaan.name) %>&background=7f97d9&color=fff'">
                    </div>

                    <div class="relative z-10">
                        <h4 class="text-lg font-black text-slate-800 mb-2 group-hover:text-[#7f97d9] transition-colors line-clamp-1">
                            <%= perusahaan.name %>
                        </h4>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-6">Partner Industry</p>
                        
                        <a href="/dashboard/siswa/company/<%= perusahaan._id %>" 
                           class="inline-block w-full py-3.5 bg-white border-2 border-slate-100 text-[#7f97d9] text-[11px] font-black uppercase tracking-widest rounded-2xl hover:bg-[#7f97d9] hover:text-white hover:border-[#7f97d9] shadow-sm transition-all duration-300">
                            Lihat Profil
                        </a>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full py-24 text-center bg-white rounded-[3rem] border border-dashed border-slate-200">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <h2 class="text-2xl font-black text-slate-800 mb-2">Belum Ada Mitra</h2>
                <p class="text-slate-400 font-medium">Saat ini belum ada perusahaan mitra yang terdaftar.</p>
            </div>
        <% } %>
    </div>
</main>

<script>
    function filterCompanies() {
        const input = document.getElementById('companySearch').value.toLowerCase();
        const grid = document.getElementById('companyGrid');
        const cards = document.getElementsByClassName('company-card');
        let foundAny = false;

        Array.from(cards).forEach(card => {
            const name = card.querySelector('h4').innerText.toLowerCase();
            
            if (name.includes(input)) {
                
                card.style.display = ""; 
                card.style.opacity = "1";
                foundAny = true;
            } else {
                
                card.style.display = "none";
                card.style.opacity = "0";
            }
        });

        let noResultMsg = document.getElementById('no-search-result');
        
        if (!foundAny) {
            if (!noResultMsg) {
                noResultMsg = document.createElement('div');
                noResultMsg.id = 'no-search-result';
                noResultMsg.className = 'col-span-full py-20 text-center bg-white rounded-[3rem] border border-slate-100 shadow-sm';
                noResultMsg.innerHTML = `
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <h3 class="text-lg font-black text-slate-800">Perusahaan tidak ditemukan</h3>
                        <p class="text-sm text-slate-400 mt-1">Coba gunakan kata kunci lain.</p>
                    </div>
                `;
                grid.appendChild(noResultMsg);
            }
        } else {
            if (noResultMsg) noResultMsg.remove();
        }
    }
</script>

<%- include('partials/footer') %>