<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Lengkapi Profil - STM JOB</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
        .custom-file-upload { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .custom-file-upload:hover { border-color: #7f97d9; background-color: rgba(127, 151, 217, 0.05); }
    </style>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-6 py-12">

  <div class="max-w-xl w-full">
    <div class="text-center mb-8 px-4">
        <img src="/images/LOGO-STM.png" class="h-12 mx-auto mb-4" alt="Logo">
        <h1 class="text-3xl font-black text-slate-800 tracking-tight break-words">Lengkapi Profil Siswa</h1>
        <p class="text-slate-500 mt-2 font-medium">Lengkapi data untuk standar identitas dunia kerja.</p>
    </div>

    <div class="bg-white p-6 md:p-10 rounded-[2.5rem] shadow-xl border border-slate-100 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-[#7f97d9]"></div>
        
        <form id="setupForm" action="/api/siswa/setup" method="POST" enctype="multipart/form-data" class="space-y-6">
            
            <div class="flex flex-col items-center mb-8">
                <div class="relative group">
                    <div class="h-24 w-24 rounded-3xl bg-slate-100 border-2 border-dashed border-slate-200 flex items-center justify-center overflow-hidden mb-2">
                        <% 
                            const avatarDefault = "https://ui-avatars.com/api/?name=" + encodeURIComponent(user.name) + "&background=7f97d9&color=fff";
                        %>
                        <img id="preview-foto" src="<%= avatarDefault %>" class="w-full h-full object-cover">
                    </div>
                    <label for="foto" class="absolute bottom-0 right-0 bg-slate-900 text-white p-1.5 rounded-xl cursor-pointer shadow-lg hover:bg-[#7f97d9] transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </label>
                    <input type="file" name="foto" id="foto" accept=".jpg,.jpeg,.png" class="hidden">
                </div>
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mt-2 text-center">
                    Pas Foto (Maks 10MB)
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">NIS Siswa</label>
                    <input type="text" name="nis" id="nis" required maxlength="15"
                        value="<%= old_data ? old_data.nis : '' %>"
                        pattern="[0-9]*" inputmode="numeric"
                        class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#7f97d9] outline-none transition-all font-semibold text-slate-700"
                        placeholder="Contoh: 212210001">
                </div>

                <div>
                    <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Jurusan</label>
                    <select name="kelas" id="kelas" required
                        class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#7f97d9] outline-none transition-all font-semibold text-slate-700 appearance-none">
                        <option value="" disabled selected>Pilih Jurusan</option>
                        <optgroup label="PPLG">
                            <option value="SIJA" <%= old_data && old_data.kelas === 'SIJA' ? 'selected' : '' %>>SIJA</option>
                            <option value="RPL" <%= old_data && old_data.kelas === 'RPL' ? 'selected' : '' %>>RPL</option>
                        </optgroup>
                        <optgroup label="Broadcasting">
                            <option value="PSPT" <%= old_data && old_data.kelas === 'PSPT' ? 'selected' : '' %>>PSPT</option>
                        </optgroup>
                        </select>
                </div>
            </div>

            <div>
                <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">
                    Dokumen CV (PDF/DOCX)
                </label>
                <label for="cv" class="custom-file-upload flex items-center justify-between w-full px-5 py-4 bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl cursor-pointer">
                    <div class="flex items-center gap-3 min-w-0 flex-1"> <div class="p-2 bg-white rounded-xl shadow-sm flex-shrink-0">
                            <svg class="w-5 h-5 text-[#7f97d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        </div>
                        <span id="cv-filename" class="text-xs font-bold text-slate-400 tracking-tight truncate">Pilih CV (Maks 20MB)</span>
                    </div>
                    <span class="text-[9px] flex-shrink-0 font-black text-white bg-[#7f97d9] px-3 py-1.5 rounded-lg uppercase tracking-widest ml-2">Upload</span>
                </label>
                <input type="file" name="cv" id="cv" accept=".pdf,.docx" class="hidden">
            </div>

            <div>
                <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Keahlian</label>
                <input type="text" name="skill" required maxlength="100"
                    value="<%= old_data ? old_data.skill : '' %>"
                    class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#7f97d9] outline-none transition-all font-semibold text-slate-700 break-words"
                    placeholder="Web Design, AutoCAD, PLC">
            </div>

            <button type="submit" 
                class="w-full py-4 bg-slate-900 text-white rounded-2xl text-xs font-black hover:bg-[#7f97d9] transition-all uppercase tracking-[0.2em] shadow-xl active:scale-[0.98]">
                Simpan & Masuk Dashboard
            </button>
        </form>
    </div>

    <p class="text-center text-slate-400 text-[10px] mt-8 font-black uppercase tracking-widest">
        &copy; 2026 COMNETA 50 • SMKN 1 CIMAHI
    </p>
  </div>

  <script>
    const setupForm = document.getElementById('setupForm');
    const fotoInput = document.getElementById('foto');
    const cvInput = document.getElementById('cv');
    const nisInput = document.getElementById('nis');

    fotoInput.onchange = function() {
        const file = this.files[0];
        const preview = document.getElementById('preview-foto');
        if (file) {
            if (file.size > 10 * 1024 * 1024) {
                Swal.fire('Gagal', 'Foto maksimal 10MB!', 'error');
                this.value = ""; return;
            }
            const reader = new FileReader();
            reader.onload = e => { preview.src = e.target.result; }
            reader.readAsDataURL(file);
        }
    };

    cvInput.onchange = function() {
        const file = this.files[0];
        const display = document.getElementById('cv-filename');
        if (file) {
            if (file.size > 20 * 1024 * 1024) {
                Swal.fire('Gagal', 'CV maksimal 20MB!', 'error');
                this.value = ""; 
                display.innerText = "Pilih CV (Maks 20MB)";
                return;
            }
            const ext = file.name.split('.').pop().toLowerCase();
            if (ext !== 'pdf' && ext !== 'docx') {
                Swal.fire('Format Salah', 'Gunakan format PDF atau DOCX', 'warning');
                this.value = ""; 
                display.innerText = "Pilih CV (Maks 20MB)";
                return;
            }
            display.innerText = file.name;
            display.classList.replace('text-slate-400', 'text-slate-700');
        } else {
            display.innerText = "Pilih CV (Maks 20MB)";
            display.classList.replace('text-slate-700', 'text-slate-400');
        }
    };

    setupForm.onsubmit = function(e) {
        if (!/^\d+$/.test(nisInput.value)) {
            e.preventDefault();
            Swal.fire('NIS Tidak Valid', 'NIS hanya boleh berisi angka.', 'error');
            return false;
        }

        Swal.fire({
            title: 'Sedang Memproses...',
            text: 'Data profil sedang disimpan ke sistem.',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });
    };
  </script>

  <% if (typeof error_messages !== 'undefined' && error_messages.length > 0) { %>
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Kesalahan Upload',
            text: '<%= error_messages[0] %>',
            confirmButtonColor: '#7f97d9'
        });
    </script>
  <% } %>

</body>
</html>