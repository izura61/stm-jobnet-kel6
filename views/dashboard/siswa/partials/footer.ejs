<footer class="bg-white border-t border-slate-100 py-10 px-8 mt-20">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="flex flex-col items-center md:items-start gap-4">
                <div class="flex items-center gap-3">
                    <img src="/images/LOGO-STM.png" class="h-10 w-auto opacity-80" alt="Logo STM">
                    <div class="text-left">
                        <p class="font-black text-slate-800 text-sm tracking-tighter leading-tight uppercase">STM JOB PORTAL</p>
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">SMK Negeri 1 Cimahi</p>
                    </div>
                </div>
                <p class="text-[10px] text-slate-400 font-medium">© 2026 COMNETA 50. All Rights Reserved.</p>
            </div>
            
            <div class="flex gap-6">
                <a href="/dashboard/siswa/help" class="text-[10px] text-slate-400 font-bold uppercase hover:text-[#7f97d9] transition-all">Pusat Bantuan</a>
                <a href="/dashboard/siswa/acc_setting" class="text-[10px] text-slate-400 font-bold uppercase hover:text-[#7f97d9] transition-all">Pengaturan</a>
            </div>
        </div>
    </footer>

    <script>
        /**
         * LOGIKA DROPDOWN PROFIL (Sama dengan Perusahaan)
         */
        const profileBtn = document.getElementById('profileDropdownBtn');
        const profileMenu = document.getElementById('profileMenu');
        const profileContainer = document.getElementById('profileDropdownContainer');
        
        if (profileBtn) {
            profileBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                profileMenu.classList.toggle('hidden');
            });
        }

        /**
         * LOGIKA PENCARIAN (Hanya jalan jika ada elemen searchInput)
         */
        const searchInput = document.getElementById('searchInput');
        const suggestionsBox = document.getElementById('searchSuggestions');
        
        if(searchInput && suggestionsBox) {
            // Mengambil data dari card perusahaan yang ada di halaman
            const cardsData = Array.from(document.querySelectorAll('.company-card')).map(card => ({
                name: card.dataset.name || '',
                url: card.dataset.url || '#'
            }));

            searchInput.addEventListener('input', (e) => {
                const val = e.target.value.toLowerCase();
                suggestionsBox.innerHTML = '';
                
                if (val.length < 1) { 
                    suggestionsBox.classList.add('hidden'); 
                    return; 
                }
                
                const matches = cardsData.filter(c => c.name.toLowerCase().includes(val));
                
                if (matches.length > 0) {
                    suggestionsBox.classList.remove('hidden');
                    matches.forEach(item => {
                        const div = document.createElement('div');
                        div.className = 'px-6 py-4 hover:bg-slate-50 cursor-pointer flex items-center justify-between border-b border-slate-100 last:border-0 transition-all';
                        div.innerHTML = `
                            <div class="flex flex-col">
                                <span class="font-bold text-slate-700 text-sm">${item.name}</span>
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Mitra Industri</span>
                            </div>
                            <svg class="h-4 w-4 text-[#7f97d9]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        `;
                        div.onclick = () => window.location.href = item.url;
                        suggestionsBox.appendChild(div);
                    });
                } else {
                    suggestionsBox.innerHTML = '<div class="px-6 py-4 text-slate-400 italic text-sm">Perusahaan tidak ditemukan...</div>';
                    suggestionsBox.classList.remove('hidden');
                }
            });
        }

        /**
         * GLOBAL CLICK: Menutup semua menu jika klik di luar area
         */
        document.addEventListener('click', (e) => {
            // Tutup Dropdown Profil
            if (profileContainer && !profileContainer.contains(e.target)) {
                profileMenu.classList.add('hidden');
            }
            // Tutup Box Pencarian
            if (searchInput && suggestionsBox && !searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) {
                suggestionsBox.classList.add('hidden');
            }
        });
    </script>
</body>
</html>