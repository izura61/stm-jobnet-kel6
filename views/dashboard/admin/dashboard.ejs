<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SIJA-JOBNET | Dashboard </title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
  <script src="https://unpkg.com/scrollreveal"></script>

  <style>
    @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap");
    body { font-family: "Plus Jakarta Sans", sans-serif; }
  </style>
</head>

<body class="bg-slate-100 min-h-screen">

  <div class="flex min-h-screen p-6 gap-6">

    <aside class="w-64 bg-white rounded-2xl shadow-[10px_0_40px_rgba(0,0,0,0.18)] flex flex-col">

      <div class="p-6 font-bold text-xl border-b">
        STMONE
      </div>

      <nav class="p-6 flex-1">
        <ul class="space-y-3">

          <li>
            <a href="/admin/dashboard"
               class="block py-2 px-4 rounded-lg <%= currentPage === 'dashboard' ? 'bg-blue-600 text-white font-semibold' : 'text-gray-700 hover:bg-gray-100' %>">
              Dashboard
            </a>
          </li>

          <li>
            <a href="/admin/user-management"
               class="block py-2 px-4 rounded-lg hover:bg-gray-100 font-semibold transition">
              User Management
            </a>
          </li>
            <li>
            <a href="/admin/report-management"
               class="block py-2 px-4 rounded-lg hover:bg-gray-100 font-semibold transition">
              Report Management
            </a>
          </li>
           <li>
            <a href="/admin/web-monitoring"
               class="block py-2 px-4 rounded-lg hover:bg-gray-100 font-semibold transition">
              Web Monitoring
            </a>
          </li>
          <li>
            <a href="/admin/logout"
               class="block py-2 px-4 rounded-lg hover:bg-red-100 text-red-600 font-semibold transition">
              Logout
            </a>
          </li>

        </ul>
      </nav>

    </aside>

    <main class="flex-1 bg-white rounded-2xl p-8 shadow-lg overflow-auto">

    <h1 class="text-3xl font-extrabold mb-8 !text-blue-600">
      Dashboard 
    </h1>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">

        <div class="bg-slate-50 p-6 rounded-2xl shadow-md hover:scale-105 transition">
          <div class="text-blue-600 text-3xl mb-3">
            <i class="fas fa-building"></i>
          </div>
          <h3 class="font-bold">Total Perusahaan</h3>
          <p class="text-2xl font-semibold"><%= totalCompanies %></p>
        </div>

        <div class="bg-slate-50 p-6 rounded-2xl shadow-md hover:scale-105 transition">
          <div class="text-green-600 text-3xl mb-3">
            <i class="fas fa-user-plus"></i>
          </div>
          <h3 class="font-bold">Perusahaan Baru</h3>
          <p class="text-2xl font-semibold"><%= notifications.length %></p>
        </div>

        <div class="bg-slate-50 p-6 rounded-2xl shadow-md hover:scale-105 transition">
          <div class="text-purple-600 text-3xl mb-3">
            <i class="fas fa-users"></i>
          </div>
          <h3 class="font-bold">Total Siswa</h3>
          <p class="text-2xl font-semibold"><%= totalSiswa %></p>
        </div>

        <div class="bg-slate-50 p-6 rounded-2xl shadow-md hover:scale-105 transition">
          <div class="text-orange-600 text-3xl mb-3">
            <i class="fas fa-briefcase"></i>
          </div>
          <h3 class="font-bold">Total Lowongan</h3>
          <p class="text-2xl font-semibold"><%= totalLowongan %></p>
        </div>

      </div>

      <h2 class="text-2xl font-bold mb-4">
        Notifikasi Pendaftaran Perusahaan Baru
      </h2>

      <% if (notifications && notifications.length > 0) { %>
        <div class="space-y-4 max-h-[400px] overflow-y-auto">

          <% notifications.forEach(notification => { %>

            <div class="bg-slate-50 p-5 rounded-2xl shadow-md flex justify-between items-center">

              <div>
                <p class="font-bold text-lg">
                  <%= notification.name %>
                </p>
                <p class="text-sm text-gray-600">
                  Email: <%= notification.email %>
                </p>
                <p class="text-xs text-gray-400">
                  Terdaftar:
                  <%= new Date(notification.createdAt).toLocaleDateString() %>
                </p>
              </div>

              <div class="flex gap-2">

                <form action="/admin/company/approve/<%= notification._id %>" method="POST">
                  <button type="submit"
                          class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition">
                    Terima
                  </button>
                </form>

                <form action="/admin/company/reject/<%= notification._id %>" method="POST">
                  <button type="submit"
                          class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition">
                    Tolak
                  </button>
                </form>

              </div>

            </div>

          <% }) %>

        </div>
      <% } else { %>
        <p class="text-gray-500">Tidak ada notifikasi baru.</p>
      <% } %>

    </main>

  </div>

  <script>
    ScrollReveal().reveal(".shadow-md", {
      delay: 150,
      distance: "40px",
      origin: "bottom",
      duration: 800,
      interval: 100
    });
  </script>

</body>
</html>