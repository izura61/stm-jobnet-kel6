<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SIJA-JOBNET | Web Monitoring</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <script src="https://unpkg.com/scrollreveal"></script>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap");
    body { font-family: "Plus Jakarta Sans", sans-serif; }
  </style>
</head>

<body class="bg-slate-100 min-h-screen">
  <div class="flex min-h-screen p-6 gap-6">
    <aside class="w-64 bg-white rounded-2xl shadow-[10px_0_40px_rgba(0,0,0,0.18)] flex flex-col">
      <div class="p-6 font-bold text-xl border-b text-blue-600">STMONE</div>
      <nav class="p-6 flex-1">
        <ul class="space-y-3">
          <li><a href="/admin/dashboard" class="block py-2 px-4 rounded-lg <%= currentPage === 'dashboard' ? 'bg-blue-600 text-white font-semibold' : 'text-black font-semibold hover:bg-slate-50' %>">Dashboard</a></li>
          <li><a href="/admin/user-management" class="block py-2 px-4 rounded-lg <%= currentPage === 'user-management' ? 'bg-blue-600 text-white font-semibold' : 'text-black font-semibold hover:bg-slate-50' %>">User Management</a></li>
          <li><a href="/admin/report-management" class="block py-2 px-4 rounded-lg <%= currentPage === 'report-management' ? 'bg-blue-600 text-white font-semibold' : 'text-black font-semibold hover:bg-slate-50' %>">Report Management</a></li>
          <li><a href="/admin/web-monitoring" class="block py-2 px-4 rounded-lg <%= currentPage === 'web-monitoring' ? 'bg-blue-600 text-white font-semibold' : 'text-black font-semibold hover:bg-slate-50' %>">Web Monitoring</a></li>
          <li><a href="/admin/logout" class="block py-2 px-4 rounded-lg hover:bg-red-100 text-red-600 font-semibold transition">Logout</a></li>
        </ul>
      </nav>
    </aside>

    <main class="flex-1 space-y-6">
      <h1 class="text-3xl font-bold flex items-center gap-3 text-slate-800">
        <i class="fas fa-server text-blue-600"></i>
        Web Monitoring
      </h1>

      <section class="bg-white rounded-xl shadow-md p-6">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-semibold text-slate-800">Status Aktivitas User</h2>
            <span class="text-xs text-slate-400 font-medium italic">*Log diperbarui otomatis (1 baris per user)</span>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full table-fixed text-sm border-collapse">
            <thead class="bg-slate-100 text-slate-600">
              <tr>
                <th class="p-3 text-left w-1/4 border-b">Nama</th>
                <th class="p-3 text-left w-1/6 border-b">Role</th>
                <th class="p-3 text-left w-1/4 border-b">Aktivitas Terakhir</th>
                <th class="p-3 text-left w-1/4 border-b">Device ID</th>
                <th class="p-3 text-left w-1/4 border-b">Waktu Update</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof logs !== 'undefined' && logs && logs.length > 0) { %>
                <% logs.forEach(log => { %>
                    <tr class="border-b hover:bg-slate-50 transition">
                      <td class="p-3 align-middle truncate font-medium text-slate-800">
                        <%= log.name || 'Unknown' %>
                      </td>
                      <td class="p-3 align-middle">
                        <% if(log.role === "admin"){ %>
                          <span class="px-2 py-1 text-[10px] uppercase font-bold rounded bg-yellow-100 text-yellow-700">STMONE</span>
                        <% } else if(log.role === "perusahaan"){ %>
                          <span class="px-2 py-1 text-[10px] uppercase font-bold rounded bg-blue-100 text-blue-600">Perusahaan</span>
                        <% } else if(log.role === "siswa"){ %>
                          <span class="px-2 py-1 text-[10px] uppercase font-bold rounded bg-green-100 text-green-600">Siswa</span>
                        <% } else { %>
                          <span class="px-2 py-1 text-[10px] uppercase font-bold rounded bg-gray-200 text-gray-700">Guest</span>
                        <% } %>
                      </td>
                      <td class="p-3 align-middle">
                        <span class="px-2 py-1 bg-slate-100 rounded-md text-slate-600 font-mono text-[11px]">
                            <%= log.action || '/' %>
                        </span>
                      </td>
                      <td class="p-3 align-middle text-slate-500 font-mono text-[11px] truncate">
                        <%= log.deviceId %>
                      </td>
                      <td class="p-3 align-middle text-slate-600 font-medium">
                        <%= new Date(log.createdAt).toLocaleString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit', day: '2-digit', month: '2-digit', year: 'numeric' }) %>
                      </td>
                    </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="p-12 text-center text-slate-400 italic">Belum ada aktivitas tercatat</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <script>
    ScrollReveal().reveal("section", { delay: 150, distance: "40px", origin: "bottom", duration: 800 });
  </script>
</body>
</html>